{
  "name": "balancirk-member-spa",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first Angular one-page app for the Balancirk member module",
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
