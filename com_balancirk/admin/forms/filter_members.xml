<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field name="search"
            type="text"
            inputmode="search"
            label="COM_BALANCIRK_FILTER_SEARCH_LABEL"
            description="COM_BALANCIRK_FILTER_SEARCH_DESC"
            hint="JSEARCH_FILTER" />
        <field name="email"
            type="text"
            inputmode="email"
            label="COM_BALANCIRK_FILTER_EMAIL_LABEL"
            description="COM_BALANCIRK_FILTER_EMAIL_DESC"
            hint="JSEARCH_FILTER" />
    </fields>
    <fields name="list">
        <field name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.id ASC"
            onchange="this.form.submit();">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
            <option value="a.name ASC">JGRID_HEADING_ORDERING_ASC</option>
            <option value="a.name DESC">JGRID_HEADING_ORDERING_DESC</option>
            <option value="a.surname ASC">JSTATUS_ASC</option>
            <option value="a.surname DESC">JSTATUS_DESC</option>
            <option value="a.email ASC">JGLOBAL_TITLE_ASC</option>
            <option value="a.email DESC">JGLOBAL_TITLE_DESC</option>
            <option value="a.street ASC">JCATEGORY_ASC</option>
            <option value="a.street DESC">JCATEGORY_DESC</option>
            <option value="a.postalcode ASC">JGRID_HEADING_ACCESS_ASC</option>
            <option value="a.postalcode DESC">JGRID_HEADING_ACCESS_DESC</option>
            <option value="a.municipality ASC">JASSOCIATIONS_ASC</option>
            <option value="a.municipality DESC">JASSOCIATIONS_DESC</option>
        </field>
        <field name="limit"
            type="limitbox"
            label="JGLOBAL_LIST_LIMIT"
            default="25"
            onchange="this.form.submit();" />
    </fields>
</form>