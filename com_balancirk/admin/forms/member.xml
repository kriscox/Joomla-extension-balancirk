<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset>
        <field name="id"
            type="number"
            label="COM_BALANCIRK_LABEL_ID"
            default="0"
            class="readonly"
            readonly="true" />
        <field name="name"
            type="text"
            label="COM_BALANCIRK_LABEL_NAME"
            size="50"
            required="true" />
        <field name="surname"
            type="text"
            label="COM_BALANCIRK_LABEL_SURNAME"
            size="50"
            required="true" />
        <field name="username"
            type="text"
            label="COM_BALANCIRK_LABEL_USERNAME"
            size="50"
            required="true" />
        <field name="email"
            type="email"
            label="COM_BALANCIRK_LABEL_EMAIL"
            required="true" />
        <field name="street"
            type="text"
            label="COM_BALANCIRK_LABEL_STREET"
            size="255" />
        <field name="number"
            type="text"
            label="COM_BALANCIRK_LABEL_NUMBER"
            size="10" />
        <field name="bus"
            type="text"
            label="COM_BALANCIRK_LABEL_BUS"
            size="10" />
        <field name="postalcode"
            type="text"
            label="COM_BALANCIRK_LABEL_POSTALCODE"
            size="10" />
        <field name="municipality"
            type="text"
            label="COM_BALANCIRK_LABEL_MUNICIPALITY"
            size="50" />
        <field name="phone"
            type="text"
            label="COM_BALANCIRK_LABEL_PHONE"
            size="15" />
        <field name="subscription_date"
            label="COM_BALANCIRK_LABEL_SUBSCRIPTION_DATE"
            type="calendar"
            required="false"/>
        <field name="ordering"
            type="ordering"
            label="COM_BALANCIRK_LABEL_ORDERING"
            content_type="com_balancirk.member" />
    </fieldset>
</form>