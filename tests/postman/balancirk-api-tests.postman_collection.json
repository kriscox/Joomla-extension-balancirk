{
  "info": {
    "name": "Balancirk API Tests",
    "description": "Comprehensive regression tests for the Balancirk API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "balancirk-api-tests"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}/api/index.php/v1/balancirk",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_student_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_member_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "test_lesson_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has token\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('token');",
                  "    pm.collectionVariables.set('jwt_token', jsonData.token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{test_username}}\",\n  \"password\": \"{{test_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/index.php/v1/users/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "index.php",
                "v1",
                "users",
                "token"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Students API",
      "item": [
        {
          "name": "Get All Students",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is valid JSON API format\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Content-Type is application/vnd.api+json\", function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/vnd.api+json');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.api+json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/students",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "students"
              ]
            }
          }
        },
        {
          "name": "Create New Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response contains created student data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "    pm.collectionVariables.set('test_student_id', jsonData.data.id);",
                  "});",
                  "",
                  "pm.test(\"Student has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    var attributes = jsonData.data.attributes;",
                  "    pm.expect(attributes).to.have.property('name');",
                  "    pm.expect(attributes).to.have.property('firstname');",
                  "    pm.expect(attributes).to.have.property('birthdate');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.api+json"
              },
              {
                "key": "Accept",
                "value": "application/vnd.api+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"type\": \"students\",\n    \"attributes\": {\n      \"name\": \"Test Student\",\n      \"firstname\": \"John\",\n      \"email\": \"test.student@example.com\",\n      \"birthdate\": \"2010-01-01\",\n      \"street\": \"Test Street\",\n      \"number\": \"123\",\n      \"postcode\": \"1000\",\n      \"city\": \"Brussels\",\n      \"phone\": \"+32123456789\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/students",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "students"
              ]
            }
          }
        },
        {
          "name": "Get Specific Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response contains student data\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('data');",
                  "    pm.expect(jsonData.data).to.have.property('id');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/vnd.api+json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/students/{{test_student_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "students",
                "{{test_student_id}}"
              ]
            }
          }
        },
        {
          "name": "Update Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Student was updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.attributes.phone).to.eql(\"+32987654321\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/vnd.api+json"
              },
              {
                "key": "Accept",
                "value": "application/vnd.api+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"type\": \"students\",\n    \"id\": \"{{test_student_id}}\",\n    \"attributes\": {\n      \"name\": \"Test Student Updated\",\n      \"firstname\": \"John\",\n      \"email\": \"test.student@example.com\",\n      \"birthdate\": \"2010-01-01\",\n      \"phone\": \"+32987654321\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/students/{{test_student_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "students",
                "{{test_student_id}}"
              ]
            }
          }
        }
      ]
    },
